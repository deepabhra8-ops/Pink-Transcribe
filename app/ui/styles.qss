/* Pink Transcribe Main Stylesheet - Modernized Specification Theme */

QMainWindow {
    background-color: #FFFFFF;
}

QWidget {
    font-family: 'Inter', 'Segoe UI', -apple-system, sans-serif;
    color: #111827; /* strong text */
    font-size: 14px;
}

/* Accessible Focus States */
QWidget:focus {
    border: 1px solid #0F7A75; /* secondary accent */
}

/* Control Buttons (Default states) */
QPushButton {
    background-color: #F6F7F9; /* surface neutral */
    border: 1px solid #E5E7EB; /* border neutral */
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 500;
    color: #111827;
    outline: none;
}

QPushButton:hover {
    background-color: #E5E7EB;
    border-color: #6B7280;
}

QPushButton:pressed {
    background-color: #D1D5DB;
    transform: scale(0.98);
}

QPushButton:disabled {
    background-color: #F9FAFB;
    color: #9CA3AF;
    border-color: #F3F4F6;
}

/* Primary Highlight Actions */
QPushButton#primaryAction {
    background-color: #FF6FA3; /* primary accent */
    border: 1px solid #FF6FA3;
    color: #FFFFFF;
    font-weight: 600;
}

QPushButton#primaryAction:hover {
    background-color: #FF4A8B;
    border-color: #FF4A8B;
}

QPushButton#primaryAction:pressed {
    background-color: #E63C78;
}

/* Success / Affirmative Actions */
QPushButton#successAction {
    background-color: #0F7A75; /* secondary accent */
    border: 1px solid #0F7A75;
    color: #FFFFFF;
    font-weight: 600;
}

QPushButton#successAction:hover {
    background-color: #0C615d;
    border-color: #0C615d;
}

QPushButton#successAction:pressed {
    background-color: #084946;
}

/* Large Circular Record Button */
QPushButton#recordButton {
    background-color: #FF6FA3; /* primary accent */
    border: none;
    color: #FFFFFF;
    border-radius: 24px;
    font-size: 18px;
    padding: 0px;
    margin: 0px;
}

QPushButton#recordButton:hover {
    background-color: #FF4A8B;
}

QPushButton#recordButton:pressed {
    background-color: #E63C78;
}

/* Stop Button (Circular with red outline) */
QPushButton#stopButton {
    background-color: #FFFFFF;
    border: 2px solid #E02424; /* error state */
    color: #E02424;
    border-radius: 20px;
    font-size: 14px;
}

QPushButton#stopButton:hover {
    background-color: #FDF2F2;
    border-color: #C81E1E;
    color: #C81E1E;
}

/* Side Panels & Dividers */
QFrame#sidePanel {
    background-color: #F5E8EB;
    border-right: 1px solid #EAD8DD;
}

QFrame#rightPanel {
    background-color: #F5E8EB;
    border-left: 1px solid #EAD8DD;
}

QFrame#editorContainer {
    background-color: #FFFFFF;
    border: 1px solid #EAD8DD;
    border-radius: 8px;
}

QStatusBar {
    background-color: #F5E8EB;
    border-top: 1px solid #EAD8DD;
    color: #6B7280;
    font-size: 12px;
}

QStatusBar::item {
    border: none;
}

/* ScrollBars */
QScrollBar:vertical {
    border: none;
    background-color: #F6F7F9;
    width: 8px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background-color: #D1D5DB;
    min-height: 20px;
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background-color: #9CA3AF;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    border: none;
    background-color: #F6F7F9;
    height: 8px;
    margin: 0px;
}

QScrollBar::handle:horizontal {
    background-color: #D1D5DB;
    min-width: 20px;
    border-radius: 4px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #9CA3AF;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}

/* Session History List & Tree */
QListWidget, QTreeWidget {
    background-color: #FFFFFF;
    border: none;
    padding: 0px;
    color: #111827;
    outline: none;
}

QListWidget::item, QTreeWidget::item {
    padding: 8px 6px;
    border-bottom: 1px solid #F3F4F6;
    border-radius: 6px;
    margin-bottom: 4px;
    color: #111827;
}

QListWidget::item:hover, QTreeWidget::item:hover {
    background-color: #F3F4F6;
}

QListWidget::item:selected, QTreeWidget::item:selected {
    background-color: #FFE4E6; /* soft pink accent background */
    border-left: 4px solid #FF6FA3; /* pink highlight line */
    color: #111827;
    font-weight: 600;
}

QTreeWidget::branch {
    background-color: transparent;
}

/* Inputs and Forms */
QLineEdit, QTextEdit {
    background-color: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 6px;
    padding: 8px;
    color: #111827;
}

QLineEdit:focus, QTextEdit:focus {
    border: 1px solid #0F7A75; /* active teal */
}

QGroupBox {
    border: 1px solid #E5E7EB;
    border-radius: 6px;
    margin-top: 12px;
    font-weight: 600;
    color: #111827;
    padding-top: 16px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px 0 5px;
}

QComboBox {
    background-color: #FFFFFF;
    border: 1.5px solid #E5E7EB;
    border-radius: 6px;
    padding: 4px 28px 4px 12px;
    color: #111827;
    font-size: 13px;
    font-weight: 500;
}

QComboBox:hover {
    border-color: #FFADC5;
    background-color: #F9FAFB;
}

QComboBox:focus {
    border-color: #FF6FA3;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 24px;
    border: none;
}

QComboBox::down-arrow {
    image: url("data:image/svg+xml;base64,");
    width: 12px;
    height: 12px;
}

QComboBox::down-arrow:hover {
    image: url("data:image/svg+xml;base64,");
}

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 4px;
    selection-background-color: #FFE4E6;
    selection-color: #FF6FA3;
    color: #111827;
    outline: none;
}

QCheckBox {
    spacing: 6px;
    font-size: 13px;
    color: #374151;
    font-weight: 500;
}

QCheckBox:hover {
    color: #111827;
}

QCheckBox:disabled {
    color: #9CA3AF;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1.5px solid #D1D5DB;
    border-radius: 4px;
    background-color: #FFFFFF;
}

QCheckBox::indicator:hover {
    border-color: #FF6FA3;
}

QCheckBox::indicator:checked {
    border-color: #FF6FA3;
    background-color: #FF6FA3;
    image: url("data:image/svg+xml;base64,");
}

QCheckBox::indicator:disabled {
    border-color: #E5E7EB;
    background-color: #F3F4F6;
}

/* Global Dialog, QMessageBox, and QInputDialog Stylesheet Styling */
QDialog, QMessageBox, QInputDialog {
    background-color: #FFFFFF;
    color: #111827;
}

QDialog QLabel {
    color: #111827;
    background-color: transparent;
}

QDialog QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    padding: 6px 12px;
    color: #111827;
    font-size: 13px;
}

QDialog QLineEdit:focus {
    border-color: #0F7A75;
}

QDialog QPushButton {
    background-color: #F6F7F9;
    border: 1px solid #E5E7EB;
    border-radius: 6px;
    padding: 6px 14px;
    color: #111827;
    font-size: 12px;
    font-weight: 500;
    min-width: 65px;
}

QDialog QPushButton:hover {
    background-color: #FFE4E6;
    border-color: #FF6FA3;
    color: #FF6FA3;
}

/* Global QMenu & Context Menu Styling */
QMenu {
    background-color: #FFFFFF;
    border: 1px solid #EAD8DD;
    border-radius: 8px;
    padding: 4px;
    font-size: 12px;
    color: #111827;
}

QMenu::item {
    padding: 6px 20px 6px 12px;
    border-radius: 5px;
    color: #111827;
    background-color: transparent;
}

QMenu::item:selected {
    background-color: #FFE4E6;
    color: #FF6FA3;
}

QMenu::item:disabled {
    color: #9CA3AF;
}

QMenu::separator {
    height: 1px;
    background: #EAD8DD;
    margin: 4px 8px;
}
